# ============================================================
# Variables de entorno — Futura Bienes Raíces Agent System
# Copia este archivo como .env y completa tus valores reales
# NUNCA subas el archivo .env al repositorio
# ============================================================

# ── Claude / Anthropic ──────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Airtable ─────────────────────────────────────────────────
# Token: https://airtable.com/create/tokens
# Base ID: abre tu base en Airtable → URL contiene /appXXXX
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...

# Nombres de tus tablas (ya configurados para Futura Bienes Raíces)
AIRTABLE_PROPIEDADES_TABLE=Propiedades_FBR
AIRTABLE_MARKETING_TABLE=Marketing_FBR
AIRTABLE_CLIENTES_TABLE=Clientes_FBR

# ── Notion ───────────────────────────────────────────────────
# Integration token: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...
NOTION_PROPIEDADES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TAREAS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Drive ─────────────────────────────────────────────
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_DRIVE_FOLDER_ID=1ABC...

# ── Meta (Facebook / Instagram) ──────────────────────────────
META_ACCESS_TOKEN=EAAxxxxxxx
META_PAGE_ID=xxxxxxxxxx
META_IG_ACCOUNT_ID=xxxxxxxxxx

# ── Trading (Agente Trader) ───────────────────────────────────
# Alpaca — paper trading gratis en alpaca.markets
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_PAPER=true   # cambiar a false para dinero real (¡con cuidado!)

# ── Búsqueda web (Agente Investigador) ───────────────────────
# Elige uno — Tavily es más preciso para agentes IA (gratis en tavily.com)
TAVILY_API_KEY=tvly-...
# Alternativa: Brave Search (search.brave.com/search/api)
BRAVE_API_KEY=BSA...

# ── Make.com / n8n ───────────────────────────────────────────
# Solo necesarias si usas los workflows de automatización visual
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── General ──────────────────────────────────────────────────
EMPRESA_NOMBRE=Futura Bienes Raíces
EMPRESA_CIUDAD=México
